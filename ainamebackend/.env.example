DB_URI=mysql+aiomysql://root:password@127.0.0.1:3306/ainame?charset=utf8mb4
POSTGRES_MEMORY_URI=postgresql://postgres:password@127.0.0.1:5432/ainame
REDIS_URL=redis://127.0.0.1:6379/0
RABBITMQ_URL=amqp://ainame_user:change-me@127.0.0.1:5672/
RAG_QUEUE_NAME=rag_document_queue
ENABLE_MOCK_PAYMENT=false
ALIPAY_ENABLED=false
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_APP_ID=your_alipay_sandbox_app_id
ALIPAY_APP_PRIVATE_KEY_PATH=certs/alipay_app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=certs/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://your-public-domain.example.com/payments/alipay/notify
ALIPAY_RETURN_URL=https://your-public-domain.example.com/payments/alipay/return
FRONTEND_BASE_URL=http://127.0.0.1:5173
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_PAY_METHOD=page

DEEPSEEK_API_KEY=your_deepseek_api_key

MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_authorization_code
MAIL_FROM=your_email@example.com
MAIL_PORT=587
MAIL_SERVER=smtp.example.com
MAIL_FROM_NAME=ainameapp
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

JWT_SECRET_KEY=change-this-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

AIGC_API_BASE_URL=
AIGC_API_KEY=
AIGC_SUBMIT_PATH=/submit
AIGC_FETCH_PATH_TEMPLATE=/task/{task_id}
AIGC_TIMEOUT_SECONDS=10
AIGC_WAN_IMAGE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
AIGC_GENERATION_TIMEOUT_SECONDS=180
PUBLIC_BASE_URL=http://127.0.0.1:8000
VISUAL_MAX_FILE_SIZE=10485760
